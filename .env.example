# ─── REQUIRED ─────────────────────────────────────────────────────────────────
# OpenAI key for GPT-4o vision extraction. If unset the backend falls back to
# Tesseract OCR (much lower quality).
OPENAI_API_KEY=sk-...

# Full JSON blob of a Google Cloud service-account key with access to the target
# spreadsheet. Paste the ENTIRE JSON on one line (Railway accepts this).
GOOGLE_CREDENTIALS_JSON={"type":"service_account", "client_email":"..."}

# ─── SPREADSHEET ─────────────────────────────────────────────────────────────
SPREADSHEET_ID=1X_gcLo3RROT11Hv9qvhiegoztk9STv4lP2aTq0Ih0Ho
SHEET_GID=384942453

# ─── OPTIONAL (tuning) ────────────────────────────────────────────────────────
# Vision model. Override if you want to test newer GPT-4o snapshots.
OPENAI_MODEL=gpt-4o-2024-08-06
OPENAI_MAX_TOKENS=16000
OPENAI_CONTINUATION_ROUNDS=5

# Max upload size in MB (413 returned if exceeded)
MAX_UPLOAD_MB=25

# Comma-separated list of allowed CORS origins. "*" allows all (dev default).
# Example for prod: CORS_ORIGINS=https://contract-importer.vercel.app
CORS_ORIGINS=*

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ─── SECURITY ─────────────────────────────────────────────────────────────────
# If set, every /api/extract + /api/import-sheets call must include
#   X-API-Token: <token>   (or ?api_token=<token> as a fallback).
# Leave empty to disable auth (dev default).
API_TOKEN=

# Per-IP rate limit. Set RATE_LIMIT_MAX=0 to disable.
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW=60

# Port (Railway injects this automatically)
PORT=8080

# ─── P3: Resilience (optional) ───────────────────────────────────
# Exponential-backoff retries on OpenAI API errors (RateLimit, Timeout, 5xx)
OPENAI_MAX_RETRIES=3
OPENAI_RETRY_INITIAL_WAIT=1.0
OPENAI_RETRY_MAX_WAIT=16.0

# Distributed rate limiting (in-memory by default; set REDIS_URL for multi-instance)
# REDIS_URL=redis://localhost:6379/0

# Prometheus metrics endpoint (enabled by default; disable with METRICS_ENABLED=0)
METRICS_ENABLED=1
